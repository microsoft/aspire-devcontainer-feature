{
    "install_aspire_exact_version": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "aspire": {
                "version": "13.2"
            }
        }
    },
    "install_aspire_latest_version": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "aspire": {
                "version": "latest"
            }
        }
    },
    "install_aspire_latest_daily_version": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "aspire": {
                "version": "latest-daily"
            }
        }
    }
}